---
// Navbar.astro
---

<nav>
  <div class="nav-logo">
    <div class="nav-logo-icon"><span>VI</span></div>
    <div class="nav-logo-text">
      VOTO INFORMADO
      <small>PERÚ · 2026</small>
    </div>
  </div>
  <ul class="nav-links">
    <li><a href="#buscador" class="active">CANDIDATOS</a></li>
    <li><a href="#propuestas">PROPUESTAS</a></li>
    <li><a href="#bicameralidad">BICAMERALIDAD</a></li>
    <li><a href="#noticias">NOTICIAS</a></li>
    <li><a href="#comentarios">COMENTARIOS</a></li>
    <li><a href="#mitos">MITOS & VERDADES</a></li>
    <li><a href="#tramites">ONPE</a></li>
  </ul>
</nav>

<script>
  const sections = document.querySelectorAll('section[id], #hero-section');
  const navLinks = document.querySelectorAll('.nav-links a');
  const sectionMap = {
    'hero-section': '#buscador',
    'buscador': '#buscador',
    'propuestas': '#propuestas',
    'bicameralidad': '#bicameralidad',
    'noticias': '#noticias',
    'comentarios': '#comentarios',
    'mitos': '#mitos',
    'tramites': '#tramites'
  };
 
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        navLinks.forEach(l => l.classList.remove('active'));
        const target = sectionMap[entry.target.id as keyof typeof sectionMap] || '#' + entry.target.id;
        const link = document.querySelector(`.nav-links a[href="${target}"]`);
        if (link) link.classList.add('active');
      }
    });
  }, { threshold: 0.3 });
 
  document.querySelectorAll('section[id]').forEach(s => observer.observe(s));
</script>
