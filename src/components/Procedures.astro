// Procedures.astro
---

<section id="tramites" style="background:#fff;">
  <div style="max-width:860px; margin:0 auto;">
    <p class="section-tag">07 / CONSULTAS RÁPIDAS</p>
    <h2 class="section-title">Trámites en un clic</h2>
    <p style="font-size:14px;color:#666;margin-bottom:1.5rem;">Acceso directo a los servicios oficiales — sin intermediarios.</p>
 
    <div class="tramites-grid">
      <div class="tramite-card" onclick="window.open('https://www.onpe.gob.pe','_blank')">
        <span class="tramite-ext">↗</span>
        <div class="tramite-icon">📍</div>
        <div class="tramite-name">¿Dónde voto?</div>
        <div class="tramite-desc">Consulta tu local de votación.</div>
        <div class="tramite-source">ONPE</div>
      </div>
      <div class="tramite-card" onclick="window.open('https://www.onpe.gob.pe','_blank')">
        <span class="tramite-ext">↗</span>
        <div class="tramite-icon">👤</div>
        <div class="tramite-name">¿Soy miembro de mesa?</div>
        <div class="tramite-desc">Verifica si fuiste sorteado.</div>
        <div class="tramite-source">ONPE</div>
      </div>
      <div class="tramite-card" onclick="window.open('https://www.jne.gob.pe','_blank')">
        <span class="tramite-ext">↗</span>
        <div class="tramite-icon">⏱</div>
        <div class="tramite-name">¿Tengo multas?</div>
        <div class="tramite-desc">Revisa tus deudas electorales.</div>
        <div class="tramite-source">JNE</div>
      </div>
    </div>
  </div>
</section>
