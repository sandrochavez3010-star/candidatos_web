        </div>
      </div>

    </div>
  </div>
</section>

<style>

/* 🔴 default (alerta) */
.alert-dot {
  width: 6px;
  height: 6px;
  background: #f39c12; /* naranja */
  border-radius: 50%;
}

/* 🟢 cuando NO hay problemas */
.card-alert.success .alert-dot {
  background: #2ecc71; /* verde */
}

.candidates-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16px;
}

.candidate-card {
  background: #fff;
  border: 1px solid #dcdcdc;
  transition: transform 0.25s ease, box-shadow 0.25s ease;
  
  /* 🔒 sin sombra por defecto */
  box-shadow: none;
}

/* 🔥 HOVER: aparece el “bloque” solo en esquina */
.candidate-card:hover {
  transform: translate(-6px, -6px);
  box-shadow: 6px 6px 0 0 #000; /* 👉 derecha + abajo */
}

/* 🔥 TAGS estilo borde */
.card-tags {
  margin-top: 8px;
}

.tag {
  display: inline-block;
  font-size: 9px;              /* 🔥 tamaño pequeño como imagen */
  padding: 2px 6px;            /* 🔥 compacto */
  margin: 2px 4px 0 0;
  background: #f0f0f0;         /* gris claro */
  color: #555;
  border: 1px solid #e0e0e0;   /* borde suave */
  border-radius: 2px;          /* esquinas leves */
  letter-spacing: 0.02em;
}
</style>

