---
// SearchCandidates.astro
---

<section id="buscador">
  <div style="max-width:860px; margin:0 auto;">
    <p class="section-tag">01 / BUSCADOR</p>
    <h2 class="section-title">Encuentra a tus candidatos</h2>
 
    <div class="search-box">
      <div class="search-input-wrap">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
        </svg>
        <input type="text" placeholder="Buscar por nombre o partido..." id="searchInput" oninput="filterCandidates()" />
      </div>
      <div class="search-filters">
        <div class="filter-group">
          <span class="filter-label">CARGO</span>
          <div class="filter-pills">
            <button class="pill active" onclick="setFilter(this,'todos')">TODOS</button>
            <button class="pill" onclick="setFilter(this,'presidencia')">PRESIDENCIA</button>
            <button class="pill" onclick="setFilter(this,'senado')">SENADO</button>
            <button class="pill" onclick="setFilter(this,'diputados')">DIPUTADOS</button>
          </div>
        </div>
        <div class="filter-group">
          <span class="filter-label">REGIÓN</span>
          <select class="filter-select">
            <option>Todas las regiones</option>
            <option>Lima</option>
            <option>Arequipa</option>
            <option>Cusco</option>
            <option>La Libertad</option>
            <option>Piura</option>
          </select>
        </div>
      </div>
    </div>
 
    <p class="results-count" id="resultsCount">3 CANDIDATOS ENCONTRADOS</p>
 
    <div class="candidates-grid" id="candidatesGrid">
 
      <div class="candidate-card" data-cargo="presidencia">
        <div class="card-top">
          <div class="card-avatar" style="background:#2c3e50;">KF</div>
          <div>
            <div class="card-name">Keiko Fujimori</div>
            <div class="card-party">FUERZA POPULAR</div>
            <div class="card-meta">
              <span>Presidencia</span>
              <span>Nacional</span>
            </div>
          </div>
        </div>
        <div class="card-alert">
          <div class="alert-dot"></div>
          <div class="alert-text">Investigaciones en curso — Investigación en curso por presunto lavado de activos (Caso Cócteles).</div>
        </div>
        <div class="card-tags">
          <span class="tag">2010 · FUERZA 2011</span>
          <span class="tag">2012 · FUERZA POPULAR</span>
        </div>
        <div class="card-bottom">
          <a href="#" onclick="openModal(event, 'Keiko Fujimori', 'FUERZA POPULAR', 'Presidencia', 'Nacional', 'KF', '#2c3e50')">VER FICHA COMPLETA</a>
          <button>⤴</button>
        </div>
      </div>
 
      <div class="candidate-card" data-cargo="presidencia">
        <div class="card-top">
          <div class="card-avatar" style="background:#8e1c1c;">RL</div>
          <div>
            <div class="card-name">Rafael López Aliaga</div>
            <div class="card-party">RENOVACIÓN POPULAR</div>
            <div class="card-meta">
              <span>Presidencia</span>
              <span>Nacional</span>
            </div>
          </div>
        </div>
        <div class="card-alert">
          <div class="alert-dot"></div>
          <div class="alert-text">Investigaciones en curso — Investigación por presunta evasión tributaria (Peruval).</div>
        </div>
        <div class="card-tags">
          <span class="tag">2010 · SOLIDARIDAD NAC.</span>
          <span class="tag">2020 · RENOV. POPULAR</span>
        </div>
        <div class="card-bottom">
          <a href="#" onclick="openModal(event, 'Rafael López Aliaga', 'RENOVACIÓN POPULAR', 'Presidencia', 'Nacional', 'RL', '#8e1c1c')">VER FICHA COMPLETA</a>
          <button>⤴</button>
        </div>
      </div>
 
      <div class="candidate-card" data-cargo="presidencia">
        <div class="card-top">
          <div class="card-avatar" style="background:#1a5276;">CA</div>
          <div>
            <div class="card-name">César Acuña</div>
            <div class="card-party">ALIANZA PARA EL PROGRESO</div>
            <div class="card-meta">
              <span>Presidencia</span>
              <span>Nacional</span>
            </div>
          </div>
        </div>
        <div class="card-alert">
          <div class="alert-dot"></div>
          <div class="alert-text">Investigaciones en curso — Investigación por presunto plagio académico y aportes irregulares.</div>
        </div>
        <div class="card-tags">
          <span class="tag">2005 · PERÚ POSIBLE</span>
          <span class="tag">2007 · APRA</span>
          <span class="tag">2008 · ALIANZA PROGRESO</span>
        </div>
        <div class="card-bottom">
          <a href="#" onclick="openModal(event, 'César Acuña', 'ALIANZA PARA EL PROGRESO', 'Presidencia', 'Nacional', 'CA', '#1a5276')">VER FICHA COMPLETA</a>
          <button>⤴</button>
        </div>
      </div>
 
    </div>
  </div>
</section>

<script>
  let currentFilter = 'todos';
 
  function setFilter(btn: HTMLElement, cargo: string) {
    document.querySelectorAll('.pill').forEach(p => p.classList.remove('active'));
    btn.classList.add('active');
    currentFilter = cargo;
    filterCandidates();
  }
  
  function filterCandidates() {
    const searchInput = document.getElementById('searchInput') as HTMLInputElement;
    const query = searchInput?.value.toLowerCase() || '';
    const cards = document.querySelectorAll('.candidate-card');
    let visible = 0;
    cards.forEach(card => {
      const nameEl = card.querySelector('.card-name');
      const partyEl = card.querySelector('.card-party');
      const name = nameEl?.textContent?.toLowerCase() || '';
      const party = partyEl?.textContent?.toLowerCase() || '';
      const cargo = (card as HTMLElement).dataset.cargo;
      const matchQuery = name.includes(query) || party.includes(query);
      const matchFilter = currentFilter === 'todos' || cargo === currentFilter;
      const show = matchQuery && matchFilter;
      (card as HTMLElement).style.display = show ? '' : 'none';
      if (show) visible++;
    });
    const resultsCount = document.getElementById('resultsCount');
    if (resultsCount) resultsCount.textContent = visible + ' CANDIDATOS ENCONTRADOS';
  }
</script>
