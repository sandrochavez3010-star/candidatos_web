---
const videos = [
  { id: "kRomdByjEtw", titulo: "FUJIMORI, NIETO Y GUEVARA", tema: "SEGURIDAD CIUDADANA" },
  { id: "-lRt8kL1pt4", titulo: "OLIVERA, GROZO Y PÉREZ TELLO", tema: "LUCHA CONTRA LA CORRUPCIÓN" },
  { id: "MYq8C6WNHgE", titulo: "ÁLVAREZ, LUNA Y ACUÑA", tema: "LUCHA CONTRA LA CORRUPCIÓN" },
  { id: "KN9pwhoh5FY", titulo: "WILLIAMS, LÓPEZ ALIAGA Y GONZALES", tema: "SEGURIDAD CIUDADANA" },
  { id: "Wt6QcXehWrc", titulo: "FUJIMORI, VIZCARRA, GUEVARA", tema: "LUCHA CONTRA LA CORRUPCIÓN" },
  { id: "PtCV4bBUaoQ", titulo: "MASSÉ, ESPÁ, BELMONT", tema: "LUCHA CONTRA LA CORRUPCIÓN" }
];
---

<section id="propuestas">
  <div style="max-width:1000px; margin:0 auto;">
    <p class="section-tag">02 / COMPARADOR</p>
    <h2 class="section-title">Propuestas</h2>

    <div class="video-slider">
      <button class="slider-btn" onclick="slideVideos(-1)">‹</button>

      <div class="videos-track" id="videosTrack">
        {videos.map(video => (
          <a href={`https://youtu.be/${video.id}`} target="_blank">
            <div class="video-card">
              <img src={`https://i.ytimg.com/vi/${video.id}/mqdefault.jpg`} class="video-img" />
              
              <div class="video-overlay">
                <div class="video-debate">DEBATE</div>
                <div class="video-label">{video.tema}</div>
                <div class="video-meta">{video.titulo}</div>
              </div>

              <div class="video-time">13:41</div>
            </div>
          </a>
        ))}
      </div>
      <button class="slider-btn" onclick="slideVideos(1)">›</button>
    </div>
  </div>
</section>